# ========================================================
# DocExcel Environment Configuration
# ========================================================

# Flask Application Secret Key (Change this in production)
SECRET_KEY=docexcel_super_secret_dev_key_123!

# Debug mode (Set to False in production)
DEBUG=False

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Number of Gunicorn worker processes (Keep at 2 for free tier memory limits)
MAX_WORKERS=2

# ========================================================
# OCR Configuration
# ========================================================

# Order of OCR engines to attempt (comma separated). 
# Note: For strict 512MB memory limits on Render Free, we use "tesseract".
OCR_ENGINE_PRIORITY=tesseract

# Confidence threshold below which cells are highlighted for manual review
OCR_CONFIDENCE_THRESHOLD=0.6

# OCR language codes (comma separated). Example: en,hi,gu,mr
OCR_LANGUAGES=en

# ========================================================
# File Limits
# ========================================================

# Maximum file size allowed in bytes (Default: 100MB = 104857600)
MAX_CONTENT_LENGTH=104857600

# Maximum number of files processed per batch
MAX_FILES_PER_BATCH=100
